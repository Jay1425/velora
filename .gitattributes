# Git Attributes - Line Ending Configuration
# Ensures consistent line endings across different operating systems

# Auto detect text files and normalize line endings to LF in repository
* text=auto

# Python files
*.py text eol=lf
*.pyi text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
.env.example text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Shell scripts (Unix line endings)
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts (Windows line endings)
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files (no line ending conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.db binary
*.sqlite binary
*.pyc binary
