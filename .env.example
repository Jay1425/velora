# ============================================
# VELORA - Environment Configuration Template
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# ============================================
# Admin Authentication (REQUIRED)
# ============================================

# Admin username for dashboard access
ADMIN_USERNAME=your_admin_username

# Admin password hash (NOT plain text!)
# Generate with: python generate_password_hash.py
# Or: python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('your_password'))"
ADMIN_PASSWORD_HASH=scrypt:32768:8:1$YourGeneratedHashHere

# ============================================
# Flask Security (REQUIRED)
# ============================================

# Secret key for session signing and CSRF protection
# Generate with: python -c "import os; print(os.urandom(24).hex())"
SECRET_KEY=your-random-secret-key-minimum-24-characters

# ============================================
# Database Configuration
# ============================================

# PostgreSQL Database URL (for production - Render/Neon)
# Format: postgresql://username:password@host:port/database
# If not set, SQLite will be used for local development
# DATABASE_URL=postgresql://user:password@hostname:5432/database_name

# Neon PostgreSQL example:
# DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/velora?sslmode=require

# ============================================
# Optional Configuration
# ============================================

# Enable debug mode (NEVER set to 'true' in production!)
# Default: false
# FLASK_DEBUG=false

# Server port (optional - Render sets this automatically)
# PORT=5000

# ============================================
# SETUP INSTRUCTIONS
# ============================================

# 1. Copy this file:
#    cp .env.example .env
#
# 2. Generate password hash:
#    python generate_password_hash.py
#
# 3. Generate SECRET_KEY:
#    python -c "import os; print(os.urandom(24).hex())"
#
# 4. Edit .env and replace all placeholder values
#
# 5. NEVER commit .env to version control!
#    (already protected by .gitignore)

# ============================================
# PRODUCTION SECURITY NOTES
# ============================================

# For production deployment:
# - Use environment variables on your hosting platform
# - Generate unique credentials for each environment
# - Rotate SECRET_KEY and passwords regularly
# - Enable HTTPS (automatic redirect configured)
# - Monitor admin access logs
# - Keep Flask and dependencies updated
